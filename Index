<style>
/* ═══════════════════════════════════════
   DESIGN TOKENS — WHITE THEME
═══════════════════════════════════════ */
:root {
  --white:   #ffffff;
  --bg:      #f8f9fc;
  --bg2:     #f1f3f8;
  --card:    #ffffff;
  --border:  #e4e8f0;
  --border2: #d0d7e8;
  --text:    #0d1b3e;
  --text2:   #4a5580;
  --text3:   #9ba8c4;
  --blue:    #003DA5;
  --blue2:   #1652c8;
  --blue3:   #e8eef9;
  --teal:    #00B5BD;
  --green:   #00875A;
  --green2:  #e3f5ed;
  --red:     #D42027;
  --red2:    #fde8e9;
  --gold:    #B8860B;
  --gold2:   #fef9e7;
  --purple:  #6B46C1;
  --purple2: #f0ebff;
  --shadow:  0 1px 3px rgba(13,27,62,0.08), 0 4px 16px rgba(13,27,62,0.06);
  --shadow2: 0 2px 8px rgba(13,27,62,0.12), 0 8px 32px rgba(13,27,62,0.08);
  --radius:  14px;
  --safe-top:    env(safe-area-inset-top, 44px);
  --safe-bottom: env(safe-area-inset-bottom, 34px);
}

/* ═══════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════ */
* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

html { background: var(--bg); }

body {
  font-family: 'Inter', system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  min-height: -webkit-fill-available;
  overflow-x: hidden;
  padding-bottom: calc(68px + var(--safe-bottom));
  -webkit-font-smoothing: antialiased;
}

/* ═══════════════════════════════════════
   TOPBAR
═══════════════════════════════════════ */
.topbar {
  position: sticky; top: 0; z-index: 200;
  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  padding: calc(var(--safe-top) + 8px) 18px 10px;
  display: flex; align-items: center; justify-content: space-between;
}
.topbar-left { display:flex; align-items:center; gap:10px; }
.topbar-logo {
  width: 34px; height: 34px;
  background: var(--blue);
  border-radius: 10px;
  display: flex; align-items:center; justify-content:center;
  font-size: 14px; font-weight: 900; color: white;
  letter-spacing: -0.5px; font-family: 'JetBrains Mono', monospace;
}
.topbar-title  { font-size: 16px; font-weight: 700; color: var(--text); letter-spacing:-0.3px; }
.topbar-sub    { font-size: 11px; color: var(--text3); margin-top:1px; }
.topbar-date   { font-size: 11px; color: var(--text3); font-family: 'JetBrains Mono', monospace; text-align:right; }

/* ═══════════════════════════════════════
   SCREENS
═══════════════════════════════════════ */
.screen { display:none; animation: fadeUp .22s ease both; }
.screen.active { display:block; }
@keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

/* ═══════════════════════════════════════
   SECTION LABEL
═══════════════════════════════════════ */
.sec-label {
  font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--text3);
  padding: 18px 18px 7px;
}

/* ═══════════════════════════════════════
   DATE CHIPS
═══════════════════════════════════════ */
.date-row {
  display:flex; gap:8px; padding:6px 18px 0;
  overflow-x:auto; scrollbar-width:none;
}
.date-row::-webkit-scrollbar { display:none; }
.d-chip {
  flex-shrink:0; min-width:52px;
  background:var(--card); border:1.5px solid var(--border);
  border-radius:12px; padding:8px 12px; text-align:center; cursor:pointer;
  transition:all .15s;
}
.d-chip.active {
  background:var(--blue); border-color:var(--blue);
  box-shadow:0 4px 12px rgba(0,61,165,0.25);
}
.d-chip .dn { font-size:10px; font-weight:600; color:var(--text3); letter-spacing:.5px; }
.d-chip .dd { font-size:18px; font-weight:800; line-height:1.1; margin-top:1px; }
.d-chip.active .dn, .d-chip.active .dd { color:#fff; }

/* ═══════════════════════════════════════
   RAMADAN STRIP
═══════════════════════════════════════ */
.ram-strip {
  margin:12px 18px 0;
  background:linear-gradient(135deg,#fffbeb,#fff7d6);
  border:1.5px solid #f5d76e;
  border-radius:var(--radius);
  padding:11px 14px;
  display:flex; align-items:center; gap:10px;
}
.ram-icon { font-size:22px; }
.ram-day  { font-size:13px; font-weight:700; color:#7c4f00; }
.ram-time { font-size:11px; color:#a06a10; font-family:'JetBrains Mono',monospace; margin-top:2px; }

/* ═══════════════════════════════════════
   PROGRESS BANNER
═══════════════════════════════════════ */
.prog-banner {
  margin:12px 18px 0;
  background:var(--blue);
  border-radius:var(--radius);
  padding:16px 18px;
  color:#fff;
  box-shadow:0 4px 20px rgba(0,61,165,0.28);
}
.pb-row { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px; }
.pb-label { font-size:9px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.55); margin-bottom:3px; }
.pb-val   { font-size:28px; font-weight:900; letter-spacing:-1px; line-height:1; }
.pb-pct   { font-size:24px; font-weight:900; letter-spacing:-1px; }
.pb-track { height:5px; background:rgba(255,255,255,0.2); border-radius:10px; overflow:hidden; }
.pb-fill  { height:100%; border-radius:10px; background:linear-gradient(90deg,#7dd3fc,#38bdf8); transition:width .7s cubic-bezier(.16,1,.3,1); }
.pb-fill.good { background:linear-gradient(90deg,#6ee7b7,#34d399); }
.pb-fill.warn { background:linear-gradient(90deg,#fde68a,#fbbf24); }
.pb-fill.bad  { background:linear-gradient(90deg,#fca5a5,#f87171); }
.pb-meta { display:flex; justify-content:space-between; margin-top:6px; font-size:10px; color:rgba(255,255,255,0.45); font-family:'JetBrains Mono',monospace; }

/* ═══════════════════════════════════════
   SLOT SUMMARY MINI
═══════════════════════════════════════ */
.slot-mini {
  display:grid; grid-template-columns:1fr 1fr 1fr;
  gap:8px; margin:10px 18px 0;
}
.sm-card {
  background:var(--card); border:1.5px solid var(--border);
  border-radius:12px; padding:10px 10px; text-align:center;
  box-shadow:var(--shadow);
}
.sm-label { font-size:9px; font-weight:700; color:var(--text3); letter-spacing:.5px; text-transform:uppercase; }
.sm-val   { font-size:14px; font-weight:800; font-family:'JetBrains Mono',monospace; color:var(--text); margin-top:3px; }
.sm-n7    { font-size:10px; color:var(--purple); font-family:'JetBrains Mono',monospace; margin-top:1px; }

/* ═══════════════════════════════════════
   SLOT TABS
═══════════════════════════════════════ */
.slot-tabs {
  display:flex; gap:6px; padding:4px 18px 0;
}
.s-tab {
  flex:1; background:var(--card); border:1.5px solid var(--border);
  border-radius:10px; padding:9px 4px; text-align:center;
  font-size:10px; font-weight:700; color:var(--text2);
  cursor:pointer; transition:all .15s; letter-spacing:.2px;
}
.s-tab .si { font-size:15px; display:block; margin-bottom:2px; }
.s-tab.active { background:var(--blue3); border-color:var(--blue); color:var(--blue); }

/* ═══════════════════════════════════════
   ENTRY CARDS
═══════════════════════════════════════ */
.e-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:10px; margin:12px 18px 0;
}
.e-card {
  background:var(--card); border:1.5px solid var(--border);
  border-radius:var(--radius); padding:13px 14px;
  box-shadow:var(--shadow); transition:border-color .15s;
}
.e-card:focus-within { border-color:var(--blue); box-shadow:0 0 0 3px rgba(0,61,165,0.1); }
.e-card label {
  display:block; font-size:9.5px; font-weight:700; color:var(--text3);
  letter-spacing:1px; text-transform:uppercase; margin-bottom:5px;
}
.e-card input {
  background:none; border:none; outline:none;
  color:var(--text); font-size:22px; font-weight:800;
  font-family:'JetBrains Mono',monospace; width:100%;
  -webkit-appearance:none;
}
.e-card input::placeholder { color:var(--border2); font-size:18px; }
.e-card .calc { font-size:11px; color:var(--text3); font-family:'JetBrains Mono',monospace; margin-top:3px; }

/* ═══════════════════════════════════════
   BUTTON
═══════════════════════════════════════ */
.btn-primary {
  display:block; width:calc(100% - 36px); margin:14px 18px 0;
  background:var(--blue); color:white; border:none;
  border-radius:var(--radius); padding:15px; font-size:14px;
  font-weight:700; font-family:'Inter',sans-serif; cursor:pointer;
  transition:all .15s; letter-spacing:.2px;
  box-shadow:0 4px 16px rgba(0,61,165,0.3);
}
.btn-primary:active { transform:scale(.97); box-shadow:none; }
.btn-danger { background:var(--red); box-shadow:0 4px 16px rgba(212,32,39,0.25); }

/* ═══════════════════════════════════════
   BOTTOM NAV
═══════════════════════════════════════ */
.bnav {
  position:fixed; bottom:0; left:0; right:0; z-index:300;
  background:rgba(255,255,255,0.97); backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px); border-top:1px solid var(--border);
  display:flex; padding-bottom:var(--safe-bottom);
}
.bnav-btn {
  flex:1; border:none; background:none; padding:9px 0 7px;
  display:flex; flex-direction:column; align-items:center;
  gap:3px; cursor:pointer; color:var(--text3); font-family:'Inter',sans-serif;
  transition:color .15s;
}
.bnav-btn.active { color:var(--blue); }
.bnav-btn .bi { font-size:20px; line-height:1; }
.bnav-btn .bl { font-size:10px; font-weight:600; letter-spacing:.2px; }

/* ═══════════════════════════════════════
   TOAST
═══════════════════════════════════════ */
.toast {
  position:fixed; top:calc(var(--safe-top) + 62px); left:50%;
  transform:translateX(-50%) translateY(-8px);
  background:var(--green); color:white; padding:9px 22px;
  border-radius:50px; font-size:13px; font-weight:700;
  z-index:999; opacity:0; transition:all .25s; pointer-events:none; white-space:nowrap;
  box-shadow:0 4px 16px rgba(0,135,90,0.35);
}
.toast.show { opacity:1; transform:translateX(-50%) translateY(0); }

/* ═══════════════════════════════════════
   KPI CHIPS ROW
═══════════════════════════════════════ */
.kpi-row {
  display:flex; gap:8px; padding:10px 18px 0;
  overflow-x:auto; scrollbar-width:none;
}
.kpi-row::-webkit-scrollbar { display:none; }
.kpi-chip {
  flex-shrink:0; min-width:105px;
  background:var(--card); border:1.5px solid var(--border);
  border-radius:12px; padding:12px 14px; box-shadow:var(--shadow);
}
.kpi-chip.hi { border-color:var(--blue); background:var(--blue3); }
.kc-name { font-size:9px; font-weight:700; color:var(--text3); letter-spacing:1px; text-transform:uppercase; }
.kc-val  { font-size:19px; font-weight:800; font-family:'JetBrains Mono',monospace; color:var(--text); margin-top:2px; }
.kc-sub  { font-size:10px; color:var(--text3); margin-top:1px; }

/* ═══════════════════════════════════════
   WEEKLY TABLE
═══════════════════════════════════════ */
.w-wrap {
  margin:8px 18px 0; border-radius:var(--radius);
  overflow:hidden; border:1.5px solid var(--border); background:var(--card);
  box-shadow:var(--shadow);
}
.w-row {
  display:grid; grid-template-columns:58px 1fr 1fr 52px 52px 44px;
  padding:10px 12px; border-bottom:1px solid var(--border);
  align-items:center;
}
.w-row:last-child { border-bottom:none; }
.w-row.hdr { background:var(--bg2); padding:7px 12px; }
.w-row.hdr span { font-size:9px; font-weight:700; color:var(--text3); letter-spacing:.8px; text-transform:uppercase; }
.w-row.today-row { background:var(--blue3); }
.w-row.total-row { background:var(--bg2); border-top:1.5px solid var(--border2); }
.w-day   { font-size:12px; font-weight:700; color:var(--text2); }
.w-day .ds { font-size:10px; font-weight:400; color:var(--text3); }
.w-sales { font-size:13px; font-weight:700; font-family:'JetBrains Mono',monospace; color:var(--text); }
.w-tgt   { font-size:11px; color:var(--text2); font-family:'JetBrains Mono',monospace; }
.w-pct   { font-size:11px; font-weight:700; text-align:right; }
.w-pct.good { color:var(--green); } .w-pct.bad { color:var(--red); } .w-pct.warn { color:var(--gold); }
.w-n7    { font-size:11px; font-family:'JetBrains Mono',monospace; color:var(--purple); text-align:right; }
.w-atv   { font-size:11px; font-family:'JetBrains Mono',monospace; color:var(--text2); text-align:right; }

/* ═══════════════════════════════════════
   HISTORY CARDS
═══════════════════════════════════════ */
.h-card {
  margin:8px 18px 0; background:var(--card);
  border:1.5px solid var(--border); border-radius:var(--radius);
  padding:13px 15px; display:flex; justify-content:space-between;
  align-items:center; cursor:pointer; transition:all .15s;
  box-shadow:var(--shadow);
}
.h-card:active { background:var(--bg2); transform:scale(.99); }
.h-date { font-size:13px; font-weight:700; color:var(--text); }
.h-sub  { font-size:11px; color:var(--text3); margin-top:2px; }
.h-val  { font-size:18px; font-weight:800; font-family:'JetBrains Mono',monospace; color:var(--text); text-align:right; }
.h-pct  { font-size:11px; font-weight:700; text-align:right; margin-top:1px; }

/* ═══════════════════════════════════════
   SETTINGS
═══════════════════════════════════════ */
.set-group {
  margin:8px 18px 0; background:var(--card);
  border:1.5px solid var(--border); border-radius:var(--radius);
  overflow:hidden; box-shadow:var(--shadow);
}
.set-row {
  display:flex; align-items:center; justify-content:space-between;
  padding:13px 15px; border-bottom:1px solid var(--border);
}
.set-row:last-child { border-bottom:none; }
.set-label { font-size:13px; font-weight:600; color:var(--text); }
.set-sub   { font-size:11px; color:var(--text3); margin-top:2px; }
.set-input {
  background:var(--bg2); border:1.5px solid var(--border);
  border-radius:8px; padding:6px 10px; color:var(--text);
  font-size:14px; font-weight:700; font-family:'JetBrains Mono',monospace;
  width:110px; text-align:right; outline:none;
}
.set-input:focus { border-color:var(--blue); background:var(--blue3); }

/* ═══════════════════════════════════════
   DASHBOARD
═══════════════════════════════════════ */
#screen-dashboard { padding-bottom:20px; }

.dash-hero {
  background: linear-gradient(135deg, var(--blue) 0%, #1a4db5 50%, #0e3a8c 100%);
  padding: calc(var(--safe-top) + 18px) 18px 20px;
  position:relative; overflow:hidden;
  margin-bottom:0;
}
.dash-hero::after {
  content:'B'; position:absolute; right:-20px; top:-20px;
  font-size:200px; font-weight:900; color:rgba(255,255,255,0.04);
  font-family:'Inter',sans-serif; line-height:1; pointer-events:none;
  user-select:none;
}

.dh-store-row { display:flex; justify-content:space-between; align-items:center; margin-bottom:14px; }
.dh-pill {
  background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.25);
  border-radius:100px; padding:5px 14px 5px 5px;
  display:flex; align-items:center; gap:8px;
}
.dh-dot {
  width:26px; height:26px; background:#fff; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:11px; font-weight:900; color:var(--blue);
  font-family:'JetBrains Mono',monospace;
}
.dh-name { font-size:11px; font-weight:700; color:rgba(255,255,255,0.85); letter-spacing:1px; text-transform:uppercase; }
.dh-date { font-size:11px; color:rgba(255,255,255,0.45); font-family:'JetBrains Mono',monospace; }

.dh-title { font-size:30px; font-weight:900; color:#fff; letter-spacing:-1px; line-height:1; }
.dh-sub   { font-size:11px; color:rgba(255,255,255,0.4); letter-spacing:2px; text-transform:uppercase; margin-top:4px; }
.dh-week  {
  display:inline-block; margin-top:10px;
  background:rgba(56,189,248,0.2); border:1px solid rgba(56,189,248,0.35);
  color:#7dd3fc; font-size:10px; font-weight:700; letter-spacing:1.5px;
  text-transform:uppercase; padding:3px 12px; border-radius:100px;
}

.dh-prog {
  margin-top:14px; background:rgba(255,255,255,0.12);
  border:1px solid rgba(255,255,255,0.18); border-radius:12px; padding:13px 15px;
}
.dh-pg-row { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:8px; }
.dh-pg-label { font-size:9px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.45); margin-bottom:2px; }
.dh-pg-val  { font-size:28px; font-weight:900; color:#fff; letter-spacing:-1px; line-height:1; }
.dh-pg-pct  { font-size:22px; font-weight:900; color:#7dd3fc; }
.dh-pg-track { height:4px; background:rgba(255,255,255,0.15); border-radius:10px; overflow:hidden; }
.dh-pg-fill  { height:100%; border-radius:10px; background:linear-gradient(90deg,#38bdf8,#7dd3fc); transition:width .8s cubic-bezier(.16,1,.3,1); }
.dh-pg-fill.good { background:linear-gradient(90deg,#34d399,#6ee7b7); }
.dh-pg-fill.warn { background:linear-gradient(90deg,#fbbf24,#fde68a); }
.dh-pg-fill.bad  { background:linear-gradient(90deg,#f87171,#fca5a5); }
.dh-pg-meta { display:flex; justify-content:space-between; margin-top:6px; font-size:10px; color:rgba(255,255,255,0.4); font-family:'JetBrains Mono',monospace; }

/* Dashboard KPI grid */
.dk-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; padding:12px 18px 0; }
.dk-grid3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; padding:10px 18px 0; }

.dk-card {
  background:var(--card); border:1.5px solid var(--border);
  border-radius:var(--radius); padding:14px 14px 12px;
  box-shadow:var(--shadow); position:relative; overflow:hidden;
  transition:transform .2s; cursor:default;
}
.dk-card::before {
  content:''; position:absolute; top:0; left:0; right:0;
  height:3px; border-radius:var(--radius) var(--radius) 0 0;
}
.dk-teal::before   { background:var(--teal); }
.dk-red::before    { background:var(--red); }
.dk-gold::before   { background:var(--gold); }
.dk-purple::before { background:var(--purple); }
.dk-blue::before   { background:var(--blue); }
.dk-green::before  { background:var(--green); }

.dk-label { font-size:9px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:var(--text3); margin-bottom:6px; }
.dk-value { font-size:36px; font-weight:900; color:var(--text); line-height:1; letter-spacing:-1px; margin-bottom:8px; font-family:'Inter',sans-serif; }
.dk-value.sm { font-size:28px; }
.dk-delta {
  display:inline-flex; align-items:center; gap:4px;
  font-size:11px; font-weight:700; padding:3px 9px; border-radius:100px;
}
.dk-delta.up     { color:var(--green); background:var(--green2); }
.dk-delta.down   { color:var(--red);   background:var(--red2); }
.dk-delta.neutral{ color:var(--text3); background:var(--bg2); }
.dk-bg { position:absolute; right:6px; bottom:-10px; font-size:64px; font-weight:900; color:rgba(13,27,62,0.04); line-height:1; pointer-events:none; font-family:'Inter',sans-serif; }

.dash-actions { display:flex; gap:8px; padding:10px 18px 0; }
.dash-act-btn {
  flex:1; background:var(--card); border:1.5px solid var(--border);
  border-radius:12px; padding:11px 6px;
  display:flex; flex-direction:column; align-items:center; gap:3px;
  cursor:pointer; font-size:9.5px; font-weight:700; color:var(--text2);
  letter-spacing:.5px; text-transform:uppercase; transition:all .15s;
  box-shadow:var(--shadow);
}
.dash-act-btn:active { background:var(--bg2); transform:scale(.96); }
.dash-act-btn .di { font-size:18px; }

.empty {
  text-align:center; padding:40px 20px; color:var(--text3); font-size:13px;
}
.empty .ei { font-size:36px; margin-bottom:10px; }
</style>
</head>
