<!-- ═══════════════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════════════ -->
<script>
/* ── DATA & CONSTANTS ─────────────────────────── */
const DAYS_FULL  = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const DAYS_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const MONTHS     = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const SLOTS      = [{id:0,label:'12AM–6AM',icon:'🌙'},{id:1,label:'6AM–2PM',icon:'☀️'},{id:2,label:'2PM–10PM',icon:'🌆'}];
const DEF_TGTS   = [35000,35000,35000,38000,45000,45000,40000]; // Mon–Sun

const RAMADAN = {
  '2026-02-18':{day:1,fajr:'5:34 AM',imsak:'5:24 AM'},
  '2026-02-19':{day:2,fajr:'5:33 AM',imsak:'5:23 AM'},
  '2026-02-20':{day:3,fajr:'5:32 AM',imsak:'5:22 AM'},
  '2026-02-21':{day:4,fajr:'5:31 AM',imsak:'5:21 AM'},
  '2026-02-22':{day:5,fajr:'5:31 AM',imsak:'5:21 AM'},
  '2026-02-23':{day:6,fajr:'5:30 AM',imsak:'5:20 AM'},
  '2026-02-24':{day:7,fajr:'5:29 AM',imsak:'5:19 AM'},
  '2026-02-25':{day:8,fajr:'5:28 AM',imsak:'5:18 AM'},
  '2026-02-26':{day:9,fajr:'5:27 AM',imsak:'5:17 AM'},
  '2026-02-27':{day:10,fajr:'5:27 AM',imsak:'5:17 AM'},
};

let settings = JSON.parse(localStorage.getItem('boo_settings')||'{}');
let data     = JSON.parse(localStorage.getItem('boo_data')||'{}');
let selDate  = dk(new Date());
let selSlot  = 0;

/* ── HELPERS ──────────────────────────────────── */
function dk(d){ return d.toISOString().slice(0,10); }
function gs(k,def){ return settings[k]!==undefined?settings[k]:def; }
function saveSetting(k,v){ settings[k]=v; save(); refreshAll(); }
function saveDayTgt(i,v){ if(!settings.dayTgts) settings.dayTgts=[...DEF_TGTS]; settings.dayTgts[i]=parseFloat(v)||DEF_TGTS[i]; save(); refreshAll(); }
function getDayTgt(dow){ return settings.dayTgts?settings.dayTgts[dow]||DEF_TGTS[dow]:DEF_TGTS[dow]; }
function save(){ localStorage.setItem('boo_settings',JSON.stringify(settings)); localStorage.setItem('boo_data',JSON.stringify(data)); }
function fmt(n){ if(!n||isNaN(n)) return '0'; return n>=1000?(n/1000).toFixed(1)+'K':Math.round(n)+''; }
function fmtFull(n){ return new Intl.NumberFormat('en-AE').format(Math.round(n||0)); }
function dateFromKey(k){ const [y,m,d]=k.split('-').map(Number); return new Date(y,m-1,d); }

function toast(msg, isErr){
  const t=document.getElementById('toast');
  t.textContent=msg; t.style.background=isErr?'var(--red)':'var(--green)';
  t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2200);
}

/* ── TOTALS ───────────────────────────────────── */
function getDayTotals(key){
  const d=data[key]||{};
  let sale=0,no7=0,trn=0,ff=0;
  for(let i=0;i<3;i++){
    const s=d['s'+i]||{};
    sale+=s.sale||0; no7+=s.no7||0; trn+=s.trn||0; ff+=s.ff||0;
  }
  return {
    sale, no7, trn, ff,
    atv: trn>0?sale/trn:0,
    no7p: sale>0?no7/sale*100:0,
    conv: ff>0?trn/ff*100:0,
    aura: d.aura||null,
    auraLink: d.auraLink||null,
    ipt: d.ipt||null,
  };
}

/* ── INIT ─────────────────────────────────────── */
function init(){
  updateTopbar(); buildDateChips(); buildEntryGrid(); loadSettings();
  refreshAll(); registerSW();
}

function loadSettings(){
  document.getElementById('s-store').value = gs('storeName','');
  document.getElementById('s-n7t').value   = gs('no7DailyTarget',4000);
  document.getElementById('s-n7p').value   = gs('no7PctTarget',12);
  document.getElementById('s-atv').value   = gs('atvTarget',120);
  document.getElementById('s-conv').value  = gs('convTarget',47);
  document.getElementById('s-aura').value  = gs('auraTarget',75);
  const tgts = settings.dayTgts||DEF_TGTS;
  tgts.forEach((t,i)=>{ const el=document.getElementById('t-'+i); if(el) el.value=t; });
}

function updateTopbar(){
  const now=new Date();
  document.getElementById('topbar-date').textContent = DAYS_SHORT[now.getDay()]+' '+now.getDate()+' '+MONTHS[now.getMonth()];
  const sn = gs('storeName','BOO_STORE')||'BOO_STORE';
  document.getElementById('topbar-sub').textContent = sn+' · Boots Alshaya';
}

/* ── DATE CHIPS ───────────────────────────────── */
function buildDateChips(){
  const c=document.getElementById('dateChips'); c.innerHTML='';
  const now=new Date();
  for(let i=6;i>=0;i--){
    const d=new Date(now); d.setDate(now.getDate()-i);
    const key=dk(d);
    const ch=document.createElement('div');
    ch.className='d-chip'+(key===selDate?' active':'');
    ch.innerHTML=`<div class="dn">${DAYS_SHORT[d.getDay()]}</div><div class="dd">${d.getDate()}</div>`;
    ch.onclick=()=>{ selDate=key; buildDateChips(); refreshAll(); };
    c.appendChild(ch);
  }
}

/* ── RAMADAN ──────────────────────────────────── */
function updateRamadan(){
  const info=RAMADAN[selDate];
  ['ram-strip','ram-day','ram-time'].forEach(id=>{});
  const strip=document.getElementById('ram-strip');
  const day=document.getElementById('ram-day');
  const time=document.getElementById('ram-time');
  if(info&&strip){ strip.style.display='flex'; day.textContent='Ramadan Day '+info.day+' 🌙'; time.textContent='Fajr: '+info.fajr+'  |  Imsak: '+info.imsak; }
  else if(strip){ strip.style.display='none'; }

  const dashRam=document.getElementById('dash-ram');
  const drDay=document.getElementById('dr-day');
  const drTime=document.getElementById('dr-time');
  const todayInfo=RAMADAN[dk(new Date())];
  if(todayInfo&&dashRam){ dashRam.style.display='flex'; drDay.textContent='Ramadan Day '+todayInfo.day+' 🌙'; drTime.textContent='Fajr: '+todayInfo.fajr+'  |  Imsak: '+todayInfo.imsak; }
  else if(dashRam){ dashRam.style.display='none'; }
}

/* ── SLOT TABS ────────────────────────────────── */
function switchSlot(i){ selSlot=i; SLOTS.forEach((_,j)=>{ document.getElementById('stab'+j).className='s-tab'+(j===i?' active':''); }); loadSlotInputs(); }

/* ── ENTRY GRID ───────────────────────────────── */
function buildEntryGrid(){
  const g=document.getElementById('entryGrid');
  g.innerHTML=`
    <div class="e-card"><label>💰 SALE (AED)</label><input type="number" inputmode="decimal" id="i-sale" placeholder="0.00" oninput="calcATV()"></div>
    <div class="e-card"><label>🟣 NO7 SALES</label><input type="number" inputmode="decimal" id="i-no7" placeholder="0.00" oninput="calcNo7()"></div>
    <div class="e-card"><label>🔢 TRANSACTIONS</label><input type="number" inputmode="numeric" id="i-trn" placeholder="0" oninput="calcATV()"><div class="calc" id="c-atv">ATV: —</div></div>
    <div class="e-card"><label>📱 NO7 %</label><input type="number" inputmode="decimal" id="i-n7p" placeholder="0.0" step="0.1"><div class="calc" id="c-n7p">Auto-calc</div></div>
    <div class="e-card"><label>👥 FOOTFALL</label><input type="number" inputmode="numeric" id="i-ff" placeholder="0" oninput="calcConv()"></div>
    <div class="e-card"><label>📈 CONV %</label><input type="number" inputmode="decimal" id="i-conv" placeholder="0.0" step="0.1"><div class="calc" id="c-conv">Auto-calc</div></div>
  `;
  loadSlotInputs();
}

function calcATV(){
  const sale=parseFloat(document.getElementById('i-sale')?.value)||0;
  const trn =parseFloat(document.getElementById('i-trn')?.value)||0;
  document.getElementById('c-atv').textContent = trn>0?'ATV: '+(sale/trn).toFixed(1)+' AED':'ATV: —';
  calcConv();
}
function calcNo7(){
  const sale=parseFloat(document.getElementById('i-sale')?.value)||0;
  const no7 =parseFloat(document.getElementById('i-no7')?.value)||0;
  const el=document.getElementById('c-n7p');
  const pEl=document.getElementById('i-n7p');
  if(sale>0){ const p=(no7/sale*100).toFixed(1); el.textContent='= '+p+'%'; if(pEl&&!pEl.value) pEl.value=p; }
  else el.textContent='Auto-calc';
}
function calcConv(){
  const trn=parseFloat(document.getElementById('i-trn')?.value)||0;
  const ff =parseFloat(document.getElementById('i-ff')?.value)||0;
  document.getElementById('c-conv').textContent = ff>0?'Conv: '+(trn/ff*100).toFixed(1)+'%':'Auto-calc';
}

function loadSlotInputs(){
  const slot=(data[selDate]||{})['s'+selSlot]||{};
  const map={sale:'i-sale',no7:'i-no7',trn:'i-trn',n7p:'i-n7p',ff:'i-ff',conv:'i-conv'};
  Object.entries(map).forEach(([k,id])=>{ const el=document.getElementById(id); if(el) el.value=slot[k]||''; });
  calcATV(); calcNo7(); calcConv();
}

/* ── SAVE ─────────────────────────────────────── */
function saveSlot(){
  if(!data[selDate]) data[selDate]={};
  const slot={};
  const map={sale:'i-sale',no7:'i-no7',trn:'i-trn',n7p:'i-n7p',ff:'i-ff',conv:'i-conv'};
  Object.entries(map).forEach(([k,id])=>{ const el=document.getElementById(id); if(el&&el.value) slot[k]=parseFloat(el.value); });
  if(slot.sale&&slot.trn&&!slot.atv) slot.atv=slot.sale/slot.trn;
  data[selDate]['s'+selSlot]=slot;
  save(); toast('✓ Slot saved!'); refreshAll();
}

function saveKPIs(){
  if(!data[selDate]) data[selDate]={};
  ['aura','auraLink','ipt','csat'].forEach((k,i)=>{
    const ids=['a-aura','a-link','a-ipt','a-csat'];
    const el=document.getElementById(ids[i]);
    if(el) data[selDate][k]=el.value?parseFloat(el.value):null;
  });
  save(); toast('✓ KPIs saved!');
}

function clearAll(){
  if(confirm('Clear ALL sales data? Settings will be kept.\n\nThis cannot be undone.')){ 
    data={}; localStorage.setItem('boo_data','{}'); refreshAll(); toast('🗑 Data cleared',true); 
  }
}

/* ── REFRESH ALL ──────────────────────────────── */
function refreshAll(){
  updateTopbar(); updateRamadan();
  refreshProgressBanner(); refreshSlotMini();
  refreshDashboard(); refreshWeekly(); refreshKPIScreen(); refreshHistory();
}

function refreshProgressBanner(){
  const t=getDayTotals(selDate);
  const d=dateFromKey(selDate);
  const tgt=getDayTgt(d.getDay());
  const pct=tgt>0?t.sale/tgt*100:0;
  const cls=pct>=100?'good':pct>=80?'warn':'bad';
  document.getElementById('pb-val').textContent='AED '+fmtFull(t.sale);
  document.getElementById('pb-pct').textContent=t.sale>0?pct.toFixed(1)+'%':'—%';
  document.getElementById('pb-actual').textContent='AED '+fmtFull(t.sale);
  document.getElementById('pb-target').textContent='Target: AED '+fmtFull(tgt);
  document.getElementById('pb-day-label').textContent=DAYS_FULL[d.getDay()].toUpperCase()+' PROGRESS';
  const fill=document.getElementById('pb-fill');
  fill.style.width=Math.min(pct,100)+'%'; fill.className='pb-fill '+cls;
}

function refreshSlotMini(){
  const d=data[selDate]||{};
  for(let i=0;i<3;i++){
    const s=d['s'+i]||{};
    document.getElementById('sm'+i).textContent=s.sale?'AED '+fmt(s.sale):'—';
    document.getElementById('sm'+i+'n7').textContent=s.no7?'No7: '+fmt(s.no7):'No7: —';
  }
}

/* ── DASHBOARD ────────────────────────────────── */
function refreshDashboard(){
  const now=new Date();
  const store=gs('storeName','BOO_STORE')||'BOO_STORE';
  document.getElementById('dh-dot').textContent=store[0]||'B';
  document.getElementById('dh-name').textContent=store;
  document.getElementById('dh-date').textContent=DAYS_SHORT[now.getDay()]+' '+now.getDate()+' '+MONTHS[now.getMonth()];
  const wn=Math.ceil((((now-new Date(now.getFullYear(),0,1))/86400000)+new Date(now.getFullYear(),0,1).getDay()+1)/7);
  document.getElementById('dh-week').textContent='Week '+wn+', '+now.getFullYear();

  const t=getDayTotals(dk(now));
  const tgt=getDayTgt(now.getDay());
  const pct=tgt>0?Math.round(t.sale/tgt*100):0;
  const cls=pct>=100?'good':pct>=80?'warn':'bad';
  document.getElementById('dp-sales').textContent='AED '+fmtFull(t.sale);
  document.getElementById('dp-target').textContent='Target: AED '+fmtFull(tgt);
  document.getElementById('dp-kwd').textContent=t.sale>0?'≈ KWD '+Math.round(t.sale/11.99).toLocaleString():'';
  document.getElementById('dp-pct').textContent=t.sale>0?pct+'%':'—%';
  const fill=document.getElementById('dp-fill');
  fill.style.width=Math.min(pct,100)+'%'; fill.className='dh-pg-fill '+cls;

  const auraT=parseFloat(gs('auraTarget',75));
  const atvT=parseFloat(gs('atvTarget',120));
  const n7pT=parseFloat(gs('no7PctTarget',12));
  const n7T=parseFloat(gs('no7DailyTarget',4000));

  setDKCard('dkv-aura','dkd-aura',t.auraLink!=null?t.auraLink+'%':'—',t.auraLink,auraT,'%');
  setDKCard('dkv-no7p','dkd-no7p',t.no7p>0?t.no7p.toFixed(1)+'%':'—',t.no7p,n7pT,'%');
  setDKCard('dkv-atv','dkd-atv',t.atv>0?Math.round(t.atv)+'':'—',t.atv,atvT,'');
  setDKCard('dkv-n7s','dkd-n7s',t.no7>0?fmt(t.no7):'—',t.no7,n7T,'');
  document.getElementById('dkv-trn').textContent=t.trn>0?t.trn:'—';
  const trnD=document.getElementById('dkd-trn');
  trnD.className='dk-delta '+(t.trn>0?'up':'neutral');
  trnD.textContent=t.trn>0?'↑ '+t.trn+' today':'No data';
}

function setDKCard(vid,did,display,actual,target,suf){
  document.getElementById(vid).textContent=display;
  const el=document.getElementById(did);
  if(!actual||isNaN(actual)||actual===0){ el.className='dk-delta neutral'; el.textContent='No data'; return; }
  const diff=(parseFloat(actual)-parseFloat(target));
  el.className='dk-delta '+(diff>=0?'up':'down');
  el.textContent=(diff>=0?'▲ +':'▼ ')+Math.abs(diff).toFixed(1)+suf+' vs target';
}

/* ── WEEKLY ───────────────────────────────────── */
function refreshWeekly(){
  const now=new Date();
  const dow=now.getDay(); const diff=dow===0?6:dow-1;
  const start=new Date(now); start.setDate(now.getDate()-diff);
  let tSale=0,tNo7=0,tTrn=0,tAura=0,auraC=0,tTgt=0;
  const rows=[];
  for(let i=0;i<7;i++){
    const d=new Date(start); d.setDate(start.getDate()+i);
    if(d>now) break;
    const key=dk(d); const t=getDayTotals(key); const tgt=getDayTgt(d.getDay());
    tSale+=t.sale; tNo7+=t.no7; tTrn+=t.trn; tTgt+=tgt;
    if(t.aura){ tAura+=t.auraLink||0; auraC++; }
    rows.push({d,key,t,tgt,pct:tgt>0?t.sale/tgt*100:0,isToday:key===dk(now)});
  }
  document.getElementById('wk-s').textContent='AED '+fmt(tSale);
  document.getElementById('wk-sp').textContent=tTgt>0?(tSale/tTgt*100).toFixed(1)+'% of target':'—';
  document.getElementById('wk-n7').textContent='AED '+fmt(tNo7);
  document.getElementById('wk-n7p').textContent=tSale>0?(tNo7/tSale*100).toFixed(1)+'% of sales':'—';
  document.getElementById('wk-atv').textContent=tTrn>0?'AED '+(tSale/tTrn).toFixed(0):'—';
  document.getElementById('wk-trn').textContent=fmtFull(tTrn);
  document.getElementById('wk-aura').textContent=auraC>0?(tAura/auraC).toFixed(1)+'%':'—';

  const c=document.getElementById('weekRows'); c.innerHTML='';
  rows.forEach(r=>{
    const pc=r.pct>=100?'good':r.pct>=80?'warn':(r.t.sale>0?'bad':'');
    const row=document.createElement('div');
    row.className='w-row'+(r.isToday?' today-row':'');
    row.innerHTML=`<div class="w-day">${DAYS_SHORT[r.d.getDay()]}<div class="ds">${r.d.getDate()}</div></div>
      <div class="w-sales">${r.t.sale>0?fmt(r.t.sale):'—'}</div>
      <div class="w-tgt">${fmt(r.tgt)}</div>
      <div class="w-pct ${pc}">${r.pct>0?r.pct.toFixed(0)+'%':'—'}</div>
      <div class="w-n7">${r.t.no7>0?fmt(r.t.no7):'—'}</div>
      <div class="w-atv">${r.t.atv>0?r.t.atv.toFixed(0):'—'}</div>`;
    c.appendChild(row);
  });
  const tp=tTgt>0?tSale/tTgt*100:0;
  const tpc=tp>=100?'good':tp>=80?'warn':(tSale>0?'bad':'');
  const tot=document.createElement('div'); tot.className='w-row total-row';
  tot.innerHTML=`<div class="w-day" style="font-weight:800">TOTAL</div>
    <div class="w-sales" style="color:var(--blue)">${fmt(tSale)}</div>
    <div class="w-tgt">${fmt(tTgt)}</div>
    <div class="w-pct ${tpc}">${tp>0?tp.toFixed(0)+'%':'—'}</div>
    <div class="w-n7">${tNo7>0?fmt(tNo7):'—'}</div>
    <div class="w-atv">${tTrn>0?(tSale/tTrn).toFixed(0):'—'}</div>`;
  c.appendChild(tot);
}

/* ── KPI SCREEN ───────────────────────────────── */
function refreshKPIScreen(){
  const t=getDayTotals(selDate);
  const atvT=gs('atvTarget',120); const n7pT=gs('no7PctTarget',12); const convT=gs('convTarget',47);
  const metrics=[
    {icon:'💰',label:'Total Sales',val:t.sale>0?'AED '+fmtFull(t.sale):'—',color:'var(--text)'},
    {icon:'🟣',label:'No7 Sales',val:t.no7>0?'AED '+fmtFull(t.no7):'—',sub:t.no7p>0?t.no7p.toFixed(1)+'% of sales':'',color:'var(--purple)'},
    {icon:'🔢',label:'Transactions',val:t.trn>0?fmtFull(t.trn):'—',color:'var(--text)'},
    {icon:'💳',label:'ATV',val:t.atv>0?'AED '+t.atv.toFixed(0):'—',sub:atvT?'Target: AED '+atvT:'',
      color:t.atv>0?t.atv>=atvT?'var(--green)':'var(--red)':'var(--text)'},
    {icon:'👥',label:'Footfall',val:t.ff>0?fmtFull(t.ff):'—',color:'var(--text)'},
    {icon:'📈',label:'Conversion',val:t.conv>0?t.conv.toFixed(1)+'%':'—',sub:convT?'Target: '+convT+'%':'',
      color:t.conv>0?t.conv>=convT?'var(--green)':'var(--red)':'var(--text)'},
  ];
  const g=document.getElementById('kpiSummary');
  const grid=document.createElement('div'); grid.className='e-grid';
  metrics.forEach(m=>{
    const card=document.createElement('div'); card.className='e-card';
    card.innerHTML=`<label>${m.icon} ${m.label}</label>
      <div style="font-size:20px;font-weight:800;font-family:'JetBrains Mono',monospace;color:${m.color};line-height:1.3;margin-top:4px;">${m.val}</div>
      ${m.sub?`<div style="font-size:11px;color:var(--text3);margin-top:3px;">${m.sub}</div>`:''}`;
    grid.appendChild(card);
  });
  g.innerHTML=''; g.appendChild(grid);
  const dd=data[selDate]||{};
  document.getElementById('a-aura').value=dd.aura||'';
  document.getElementById('a-link').value=dd.auraLink||'';
  document.getElementById('a-ipt').value=dd.ipt||'';
  document.getElementById('a-csat').value=dd.csat||'';
}

/* ── HISTORY ──────────────────────────────────── */
function refreshHistory(){
  const c=document.getElementById('histList'); c.innerHTML='';
  const keys=Object.keys(data).sort().reverse().slice(0,40);
  if(!keys.length){ c.innerHTML='<div class="empty"><div class="ei">📭</div>No data yet.<br>Start by entering sales in the Today tab!</div>'; return; }
  keys.forEach(key=>{
    const t=getDayTotals(key);
    if(t.sale===0&&!data[key]?.aura) return;
    const d=dateFromKey(key); const tgt=getDayTgt(d.getDay());
    const pct=tgt>0?t.sale/tgt*100:0;
    const pc=pct>=100?'var(--green)':pct>=80?'var(--gold)':'var(--red)';
    const card=document.createElement('div'); card.className='h-card';
    card.innerHTML=`<div>
        <div class="h-date">${DAYS_FULL[d.getDay()]}, ${d.getDate()} ${MONTHS[d.getMonth()]}</div>
        <div class="h-sub">TRN: ${fmtFull(t.trn)} · No7: ${t.no7>0?fmt(t.no7):'—'}${t.auraLink?` · AURA: ${t.auraLink.toFixed(1)}%`:''}</div>
      </div>
      <div>
        <div class="h-val">${t.sale>0?fmt(t.sale):'—'}</div>
        <div class="h-pct" style="color:${pc}">${pct>0?pct.toFixed(0)+'%':''}</div>
      </div>`;
    card.onclick=()=>{ selDate=key; buildDateChips(); showScreen('today'); loadSlotInputs(); refreshAll(); };
    c.appendChild(card);
  });
}

/* ── NAVIGATION ───────────────────────────────── */
function showScreen(name){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.bnav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('screen-'+name).classList.add('active');
  const nb=document.getElementById('nav-'+name); if(nb) nb.classList.add('active');
  // Hide topbar on dashboard (hero replaces it)
  document.getElementById('mainTopbar').style.display = name==='dashboard'?'none':'flex';
  if(name==='dashboard') refreshDashboard();
  if(name==='weekly')    refreshWeekly();
  if(name==='kpi')       refreshKPIScreen();
  if(name==='history')   refreshHistory();
}

/* ── PWA / SERVICE WORKER ─────────────────────── */
function registerSW(){
  if(!('serviceWorker' in navigator)) return;
  const sw=`
const C='boo-v2';
const PRE=['./'];
self.addEventListener('install',e=>{e.waitUntil(caches.open(C).then(c=>c.addAll(PRE)));self.skipWaiting();});
self.addEventListener('activate',e=>{e.waitUntil(caches.keys().then(ks=>Promise.all(ks.filter(k=>k!==C).map(k=>caches.delete(k)))));self.clients.claim();});
self.addEventListener('fetch',e=>{e.respondWith(caches.match(e.request).then(r=>r||fetch(e.request).then(res=>{if(res.ok){const rc=res.clone();caches.open(C).then(c=>c.put(e.request,rc));}return res;}).catch(()=>caches.match('./'))));});
  `;
  const blob=new Blob([sw],{type:'application/javascript'});
  navigator.serviceWorker.register(URL.createObjectURL(blob)).catch(()=>{});
}

// Boot
init();
// Hide topbar initially (dashboard is default)
document.getElementById('mainTopbar').style.display='none';
</script>
